generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

// ─── Enums ──────────────────────────────────────────────────────

enum AttendanceStatus {
  present
  absent
  leave
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DayOfWeek {
  Senin
  Selasa
  Rabu
  Kamis
  Jumat
  Sabtu
}

enum Priority {
  low
  medium
  high
}

// ─── Models ─────────────────────────────────────────────────────

model Student {
  id             String         @id @default(uuid())
  studentId      String         @unique // NIM
  name           String
  email          String         @unique
  phone          String?
  department     String
  faculty        String
  semester       Int
  password       String         // For Authentication
  faceDescriptor Json?          // Store 128D Float32Array face embedding
  attendances    Attendance[]
  leaveRequests  LeaveRequest[]
  tasks          Task[]
  enrollments    Enrollment[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Course {
  id             String         @id @default(uuid())
  code           String         @unique
  name           String
  lecturer       String
  schedules      Schedule[]
  attendances    Attendance[]
  enrollments    Enrollment[]
}

model Enrollment {
  id             String         @id @default(uuid())
  studentId      String
  courseId        String
  student        Student        @relation(fields: [studentId], references: [id])
  course         Course         @relation(fields: [courseId], references: [id])
  createdAt      DateTime       @default(now())

  @@unique([studentId, courseId])
}

model Schedule {
  id             String         @id @default(uuid())
  dayOfWeek      DayOfWeek
  startTime      String         // e.g. 09:45
  endTime        String         // e.g. 11:00
  room           String
  courseId        String
  course         Course         @relation(fields: [courseId], references: [id])
}

model Attendance {
  id             String           @id @default(uuid())
  status         AttendanceStatus
  date           DateTime         @default(now())
  meetingCount   Int
  studentId      String
  courseId        String
  student        Student          @relation(fields: [studentId], references: [id])
  course         Course           @relation(fields: [courseId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([studentId, courseId, meetingCount])
}

model LeaveRequest {
  id             String         @id @default(uuid())
  reason         String         // Sakit, Izin, etc.
  description    String?        @db.Text
  evidenceUrl    String?        // Lampiran file dokumen PDF/Image
  status         LeaveStatus    @default(PENDING)
  dateFrom       DateTime       
  dateTo         DateTime
  studentId      String
  student        Student        @relation(fields: [studentId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Task {
  id             String         @id @default(uuid())
  title          String
  description    String?        @db.Text
  deadline       DateTime
  priority       Priority       @default(medium)
  completed      Boolean        @default(false)
  studentId      String
  student        Student        @relation(fields: [studentId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}
