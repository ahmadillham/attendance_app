generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

enum AttendanceStatus {
  present
  absent
  leave
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DayOfWeek {
  Senin
  Selasa
  Rabu
  Kamis
  Jumat
  Sabtu
}

model Student {
  id             String         @id @default(uuid())
  studentId      String         @unique 
  name           String
  email          String         @unique
  phone          String?
  department     String
  faculty        String
  semester       Int
  password       String         
  faceDescriptor Json?          
  attendances    Attendance[]
  leaveRequests  LeaveRequest[]
  enrollments    Enrollment[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Course {
  id             String         @id @default(uuid())
  code           String         @unique
  name           String
  lecturer       String
  schedules      Schedule[]
  attendances    Attendance[]
  enrollments    Enrollment[]
}

model Enrollment {
  id             String         @id @default(uuid())
  studentId      String
  courseId        String
  student        Student        @relation(fields: [studentId], references: [id])
  course         Course         @relation(fields: [courseId], references: [id])
  createdAt      DateTime       @default(now())

  @@unique([studentId, courseId])
}

model Schedule {
  id             String         @id @default(uuid())
  dayOfWeek      DayOfWeek
  startTime      String         
  endTime        String         
  room           String
  courseId        String
  course         Course         @relation(fields: [courseId], references: [id])
}

model Attendance {
  id             String           @id @default(uuid())
  status         AttendanceStatus
  date           DateTime         @default(now())
  meetingCount   Int
  studentId      String
  courseId        String
  student        Student          @relation(fields: [studentId], references: [id])
  course         Course           @relation(fields: [courseId], references: [id])
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([studentId, courseId, meetingCount])
}

model LeaveRequest {
  id             String         @id @default(uuid())
  reason         String         
  description    String?        @db.Text
  evidenceUrl    String?        
  status         LeaveStatus    @default(PENDING)
  dateFrom       DateTime       
  dateTo         DateTime
  studentId      String
  student        Student        @relation(fields: [studentId], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}
